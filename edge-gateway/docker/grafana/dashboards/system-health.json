      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "edgevib-ts" },
          "format": "table",
          "rawSql": "SELECT device_id, device_type, site_id, MAX(time) AS last_data, EXTRACT(EPOCH FROM (NOW() - MAX(time)))::int AS seconds_since_last, CASE WHEN EXTRACT(EPOCH FROM (NOW() - MAX(time))) > 30 THEN 'OFFLINE' WHEN EXTRACT(EPOCH FROM (NOW() - MAX(time))) > 10 THEN 'DEGRADED' ELSE 'ONLINE' END AS connection_status FROM sensor_data WHERE source_path = 'mqtt' GROUP BY site_id, device_type, device_id ORDER BY seconds_since_last DESC",
          "refId": "A"
        }
      ],
      "title": "Device Connectivity",
      "type": "table"
    },
