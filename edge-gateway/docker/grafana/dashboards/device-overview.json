          "rawSql": "SELECT $__timeGroupAlias(time, '1m'), COUNT(*) AS \"messages\" FROM sensor_data WHERE $__timeFilter(time) AND source_path = 'mqtt' GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Message Throughput",
      "type": "timeseries"
    }
