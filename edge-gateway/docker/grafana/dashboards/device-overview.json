      "id": 5,
      "options": { "cellHeight": "md", "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false } },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "edgevib-ts" },
          "format": "table",
          "rawSql": "SELECT device_id, device_type, site_id, COALESCE(service_state, 'UNKNOWN') AS service_state, ROUND(COALESCE(last_rms, 0)::numeric, 2) AS last_rms, ROUND(COALESCE(last_temperature, 0)::numeric, 1) AS last_temperature_c, COALESCE(last_ai_class, 'N/A') AS last_ai_class, ROUND(COALESCE(last_ai_confidence, 0)::numeric, 2) AS last_ai_confidence, EXTRACT(EPOCH FROM (NOW() - last_seen))::int AS seconds_since_last, last_seen FROM device_status_view ORDER BY device_type, device_id",
          "refId": "A"
        }
      ],
      "title": "Device Status",
      "type": "table"
    },
