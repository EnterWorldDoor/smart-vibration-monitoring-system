<mxfile host="app.diagrams.net">
  <diagram name="Industrial Predictive Maintenance Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Sensor Node -->
        <mxCell id="sensor" value="Sensor Node&#xa;STM32 + ADXL345&#xa;FreeRTOS&#xa;FFT Processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="50" y="400" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- ESP32 -->
        <mxCell id="esp32" value="Communication Node&#xa;ESP32&#xa;MQTT Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="260" y="400" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- Raspberry Pi -->
        <mxCell id="gateway" value="Edge Gateway&#xa;Raspberry Pi&#xa;MQTT Broker&#xa;Edge AI Inference" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="500" y="350" width="220" height="140" as="geometry"/>
        </mxCell>

        <!-- Camera -->
        <mxCell id="camera" value="Future Camera Module&#xa;Computer Vision&#xa;OpenCV / YOLO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="500" y="520" width="220" height="100" as="geometry"/>
        </mxCell>

        <!-- Docker Platform -->
        <mxCell id="docker" value="Laptop Data Platform (Docker)&#xa;Kafka&#xa;Spark&#xa;InfluxDB&#xa;PostgreSQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="780" y="320" width="220" height="140" as="geometry"/>
        </mxCell>

        <!-- Backend -->
        <mxCell id="backend" value="Backend API&#xa;Spring Boot&#xa;REST API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="780" y="500" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Web -->
        <mxCell id="web" value="Web Dashboard&#xa;Vue + ECharts&#xa;Real-time Monitoring" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="1030" y="420" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Connections -->

        <mxCell id="c1" style="endArrow=block;" edge="1" parent="1" source="sensor" target="esp32">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c2" style="endArrow=block;" edge="1" parent="1" source="esp32" target="gateway">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c3" style="endArrow=block;" edge="1" parent="1" source="gateway" target="docker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c4" style="endArrow=block;" edge="1" parent="1" source="docker" target="backend">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c5" style="endArrow=block;" edge="1" parent="1" source="backend" target="web">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>