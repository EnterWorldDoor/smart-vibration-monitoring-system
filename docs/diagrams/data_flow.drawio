<mxfile host="app.diagrams.net">
  <diagram name="Data Flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="sensorData" value="Vibration Data&#xa;(Acceleration)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="140" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="processing" value="STM32 Processing&#xa;FFT / Feature Extraction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="260" y="300" width="200" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="mqtt" value="MQTT Transmission&#xa;ESP32 WiFi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="500" y="300" width="180" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="edgeAI" value="Edge AI Inference&#xa;Fault Detection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="720" y="300" width="200" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="stream" value="Data Streaming&#xa;Kafka / Spark" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="960" y="300" width="200" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="dashboard" value="Web Dashboard&#xa;Visualization" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="1180" y="300" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Flow -->

        <mxCell edge="1" parent="1" source="sensorData" target="processing" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="processing" target="mqtt" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="mqtt" target="edgeAI" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="edgeAI" target="stream" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="stream" target="dashboard" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>