<mxfile host="app.diagrams.net">
  <diagram name="Software Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="firmware" value="Embedded Firmware&#xa;STM32 + FreeRTOS&#xa;Sensor Task&#xa;Signal Processing Task" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="80" y="300" width="220" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="iot" value="IoT Communication&#xa;ESP32 MQTT Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="340" y="300" width="200" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="edge" value="Edge Gateway&#xa;MQTT Broker&#xa;Edge AI Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="580" y="280" width="220" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="backend" value="Backend Service&#xa;Spring Boot API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="840" y="300" width="200" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="frontend" value="Frontend Dashboard&#xa;Vue + ECharts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="1080" y="300" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Connections -->

        <mxCell edge="1" parent="1" source="firmware" target="iot" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="iot" target="edge" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="edge" target="backend" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="backend" target="frontend" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>