# ESP32-Gateway 关键配置 - 解决栈溢出问题合集
# 文件: sdkconfig.defaults
# ESP-IDF v5.5.3 兼容版本

# ============================================================
# 1. 系统事件任务栈大小 (修复 stack overflow in task sys_evt)
# ============================================================
#
# 默认值: 4096 bytes
# 问题: WiFi初始化时产生大量事件,导致栈溢出
# 解决: 增大到 8192 bytes (8KB)
CONFIG_SYSTEM_EVENT_TASK_STACK_SIZE=8192

# ============================================================
# 2. 定时器/时间任务栈大小 (修复 stack overflow in task time_auto)
# ============================================================
#
# 默认值: 2048-4096 bytes (取决于ESP-IDF版本)
# 问题: SNTP/时间同步任务需要较大栈空间处理网络回调
# 解决: 增大到 6144 bytes (6KB)
CONFIG_ESP_TIMER_TASK_STACK_SIZE=6144
CONFIG_ESP_SYSTEM_MEMPROT_FEATURE=1

# ============================================================
# 3. TCP/IP 协议栈优化
# ============================================================
#
# 增大TCP接收缓冲区,防止WiFi连接不稳定时数据丢失
CONFIG_LWIP_TCP_RECVMBOX_SIZE=32
CONFIG_LWIP_TCP_SND_BUF_SIZE=8192
CONFIG_LWIP_TCP_RECVMBUF_SIZE=8192

# ============================================================
# 已移除的无效配置项 (ESP-IDF v5.5.3中不存在)
# ============================================================
# CONFIG_FREERTOS_IDLE_TASK_STACK_SIZE=2048      ← 不存在!
# CONFIG_MAIN_TASK_STACK_SIZE=8192                ← 不存在!
